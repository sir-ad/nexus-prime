{
  "name": "nexus-prime",
  "version": "3.5.0",
  "description": "The Self-Evolving Agent Operating System — cross-session memory, token optimization, parallel sub-agents via MCP",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sir-ad/nexus-prime.git"
  },
  "homepage": "https://sir-ad.github.io/nexus-prime/",
  "bin": {
    "nexus-prime": "dist/cli.js"
  },
  "scripts": {
    "nexus:dev": "node dev-orchestrator.mjs",
    "build": "tsc && cp src/dashboard/index.html dist/dashboard/index.html",
    "dev": "tsc --watch",
    "start": "node dist/cli.js start",
    "init": "node dist/cli.js init",
    "test": "npm run build && node test/basic.test.ts && node test/memory.test.ts && node test/phantom.test.ts && node test/dashboard.test.ts && node test/docs.test.ts",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "ai",
    "agents",
    "mcp",
    "memory",
    "token-optimization",
    "multi-agent",
    "orchestration",
    "guardrails",
    "self-evolving",
    "nexus-prime"
  ],
  "author": "sir-ad",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "js-yaml": "^4.1.1",
    "pino": "^8.17.2",
    "uuid": "^9.0.1",
    "vectra": "^0.12.3",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
