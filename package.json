{
  "name": "nexus-prime",
  "version": "0.1.0",
  "description": "The Self-Evolving Agent Operating System",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nexus-prime": "./dist/cli.js"
  },
  "scripts": {
    "nexus:dev": "node dev-orchestrator.mjs",
    "build": "tsc",
