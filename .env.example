# Nexus Prime Configuration

# Network
NEXUS_PORT=3000
NEXUS_PEERS=
NEXUS_CONSENSUS=raft

# Memory
NEXUS_CORTEX_ENABLED=true
NEXUS_CORTEX_STORAGE=sqlite
NEXUS_VECTOR=hnsw
NEXUS_HIPPOCAMPUS_WINDOW=48h
NEXUS_PREFRONTAL_ITEMS=7

# Evolution
NEXUS_MUTATION_RATE=0.01
NEXUS_SELECTION_PRESSURE=0.9
NEXUS_COHERENCE_THRESHOLD=0.8

# Adapters (comma-separated)
NEXUS_ADAPTERS=openclaw,claude-code,ruflo

# Logging
NEXUS_LOG_LEVEL=info
